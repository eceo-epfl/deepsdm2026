---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const baseUrl = new URL(Astro.site ?? 'https://eceo-epfl.github.io');
const pageUrl = canonical ? new URL(canonical, baseUrl).toString() : new URL(Astro.url.pathname, baseUrl).toString();
const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/?$/, '/')}${path.replace(/^\/+/, '')}`;
const ogImage = new URL(withBase('og-image.svg'), baseUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" type="image/png" href={withBase('logo-deepsdmday.png')} />
    <link rel="apple-touch-icon" href={withBase('logo-deepsdmday.png')} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />
  </body>
</html>
